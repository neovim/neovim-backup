            "author_association": "NONE",
            "body": "Something like that:\n\n```lua\nlocal timer = assert(vim.uv.new_timer())\n\nlocal hello_msg_id = 1\nlocal ui_attach_msg_id = hello_msg_id + 1\n\nlocal hello_msg = vim.mpack.encode {\n  0,\n  hello_msg_id, -- Message identifier\n  \"nvim_set_client_info\", -- Method to call\n  -- Call parameters\n  { \"ui-snapshotter\", {}, \"remote\", {}, {} },\n}\nlocal ui_attach_msg = vim.mpack.encode {\n  0,\n  ui_attach_msg_id, -- Message identifier\n  \"nvim_ui_attach\", -- Method to call\n  -- Call parameters\n  {\n    -- Requested screen\n    -- columns and rows\n    vim.o.columns,\n    vim.o.lines,\n    -- `ui-option`\n    {\n      rgb = true,\n      ext_linegrid = true,\n      ext_hlstate = true,\n    },\n  },\n}\n\nlocal notify = function(msg, level)\n  vim.schedule(function()\n    vim.notify(msg, level)\n  end)\nend\n\nlocal pipe = assert(vim.uv.new_pipe(false))\npipe:connect(\n  vim.v.servername,\n  ---@param err string?\n  function(err)\n    if err then\n      notify(err, vim.log.levels.ERROR)\n      return\n    end\n\n    assert(timer:start(2000, 0, function()\n      if pipe:is_active() then\n        pipe:read_stop()\n      end\n      if not pipe:is_closing() then\n        pipe:close()\n      end\n      notify(\"Timed out\", vim.log.levels.INFO)\n    end))\n\n    pipe:read_start(function(read_err, data)\n      if read_err then\n        notify(read_err, vim.log.levels.ERROR)\n        return\n      elseif not data then\n        notify(\"Connection closed\", vim.log.levels.ERROR)\n        return\n      end\n\n      -- What should I do here if there is more\n      -- that one message? (3 and the half e.g.)\n      local msg = vim.mpack.decode(data)\n\n      local msg_type = msg[1]\n      if msg_type == 1 then\n        -- Handling responses\n        local msg_id, error = unpack(msg, 2, 3)\n\n        if msg_id == hello_msg_id then\n          if error ~= vim.NIL then\n            notify(\n              string.format(\"Error: %s\", vim.inspect(error)),\n              vim.log.levels.ERROR\n            )\n            return\n          end\n\n          -- nvim_set_client_info() call was successfully,\n          -- tell server to emit needed notification messages\n          pipe:write(ui_attach_msg)\n        end\n      elseif msg_type == 2 then\n        -- Handling notifications\n        notify(vim.inspect(msg), vim.log.levels.INFO)\n        if msg[2] == \"flush\" then\n          pipe:close()\n        end\n      end\n    end)\n\n    pipe:write(hello_msg)\n  end\n)\n```\n\nI want to get encoded message from string even if string contains more than one message. If the error \"trailing data in msgpack string\" pcall can't help me in any way.\n\nP.S. I'd like to retrieve all message from received chunk in the loop, until it's empty or only one partial message left",
