            "author_association": "NONE",
            "body": "If anyone is looking for a workaround that keeps the smaller hunks, here are functions for performing diffget for an entire conflict hunk and jumping between conflicts.\n\n```lua\nlocal function diffget_conflict(buffer)\n    local saved_pos = vim.fn.getpos('.')\n    local current_text = vim.fn.getline(saved_pos[2])\n\n    local start_line\n    if current_text:match('^<<<<<<<') then\n        start_line = saved_pos[2]\n    else\n        start_line = vim.fn.search('^<<<<<<<', 'bnW')\n        if start_line == 0 then\n            vim.notify('Not inside a conflict block', vim.log.levels.WARN)\n            return\n        end\n    end\n\n    vim.fn.cursor(start_line, 1)\n    local end_line = vim.fn.search('^>>>>>>>', 'nW')\n    vim.fn.setpos('.', saved_pos)\n\n    if end_line == 0 or saved_pos[2] > end_line then\n        vim.notify('Not inside a conflict block', vim.log.levels.WARN)\n        return\n    end\n\n    vim.cmd(start_line .. ',' .. end_line .. 'diffget ' .. buffer)\nend\n\nlocal function next_conflict(backwards)\n    local line = vim.fn.search(\"^<<<<<<<\", \"W\" .. (backwards and \"b\" or \"\"))\n    if line == 0 then\n        vim.notify(\"Reached end of file, no more conflicts\", vim.log.levels.WARN)\n    end\nend\n```",
