            "author_association": "CONTRIBUTOR",
            "body": "Two functions, `partial` and `pipe`, which I think are simple and intuitive and would have plenty of great uses in plugins and configs. \n```lua\n---@generic T\n---@param fn fun(...): T\n---@return fun(...): T\nlocal function partial(fn, ...)\n    local fixed = { n = select(\"#\", ...), ... }\n    return function(...)\n        local args = {}\n        vim.list_extend(args, fixed, 1, fixed.n)\n        vim.list_extend(args, { ... }, 1, select(\"#\", ...))\n        return fn(unpack(args, 1, fixed.n + select(\"#\", ...)))\n    end\nend\n\nlocal function table_pack(...)\n    return { n = select(\"#\", ...), ... }\nend\nlocal function table_unpack(list)\n    if type(list.n) == \"number\" then\n        return unpack(list, 1, list.n)\n    else\n        return unpack(list)\n    end\nend\n\n---@param fns { [number]: function, exit_early: boolean }\n---@return function\nlocal function pipe(fns)\n    local exit_early = fns.exit_early ~= false\n    return function(...)\n        local args = table_pack(...)\n        for _,fn in ipairs(fns) do\n            args = table_pack(fn(table_unpack(args)))\n            if exit_early and not args[1] then\n                return table_unpack(args)\n            end\n        end\n        return table_unpack(args)\n    end\nend\n\nlocal happy_print = pipe({ vim.inspect, partial(string.format, \"What a lovely %s it is!\"), vim.print })\n\nhappy_print(\"day\")\nhappy_print(4)\nhappy_print({ 1, 2, 3 })\n```",
