        {
            "author_association": "MEMBER",
            "body": "Something like:\n```diff\ndiff --git a/src/nvim/ex_getln.c b/src/nvim/ex_getln.c\nindex ce61832dd9..e175130d48 100644\n--- a/src/nvim/ex_getln.c\n+++ b/src/nvim/ex_getln.c\n@@ -1284,6 +1284,7 @@ static void command_line_end_wildmenu(CommandLineState *s, bool key_is_wc, int c\n   wildmenu_cleanup(&ccline);\n }\n \n+static bool did_setcmdline = false;\n static int command_line_execute(VimState *state, int key)\n {\n   if (key == K_IGNORE || key == K_NOP) {\n@@ -1309,6 +1310,7 @@ static int command_line_execute(VimState *state, int key)\n   }\n \n   if (s->c == K_EVENT || s->c == K_COMMAND || s->c == K_LUA) {\n+    did_setcmdline = false;\n     if (s->c == K_EVENT) {\n       state_handle_k_event();\n     } else if (s->c == K_COMMAND) {\n@@ -1324,6 +1326,11 @@ static int command_line_execute(VimState *state, int key)\n     if (display_tick > display_tick_saved && s->is_state.did_incsearch) {\n       may_do_incsearch_highlighting(s->firstc, s->count, &s->is_state);\n     }\n+    // If f_setcmdline() changed the cmdline treat it as such.\n+    if (did_setcmdline) {\n+      did_setcmdline = false;\n+      command_line_changed(s);\n+    }\n \n     // nvim_select_popupmenu_item() can be called from the handling of\n     // K_EVENT, K_COMMAND, or K_LUA.\n@@ -4450,6 +4457,7 @@ void f_setcmdline(typval_T *argvars, typval_T *rettv, EvalFuncData fptr)\n \n   // Use tv_get_string() to handle a NULL string like an empty string.\n   rettv->vval.v_number = set_cmdline_str(tv_get_string(&argvars[0]), pos);\n+  did_setcmdline = true;\n }\n \n /// \"setcmdpos()\" function\n```",
            "created_at": "2026-04-04T23:49:35Z",
