    "auto_merge": {
        "commit_message": "Problem:  With 'winfixbuf' set in the current window, :windo and :tabdo\n          create an extra split window, even though they only visit\n          existing windows/tabpages and don't change the current\n          window's buffer (Collin Kennedy)\nSolution: Skip the 'winfixbuf' escape in ex_listdo() for :windo and\n          :tabdo (ShivaPriyanShanmuga)\n\nfixes:  vim/vim#14301\ncloses: vim/vim#20600\n\nhttps://github.com/vim/vim/commit/5767d80b3794b17e5b61afec966fdeb7c0c4506f",
        "commit_title": "vim-patch:9.2.0702: :windo and :tabdo create an extra window with 'winfixbuf' (#40358)",
