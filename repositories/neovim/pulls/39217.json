            "diff_hunk": "@@ -1004,6 +1004,10 @@ void op_reindent(oparg_T *oap, Indenter how)\n       if (i > 1\n           && (i % 50 == 0 || i == oap->line_count - 1)\n           && oap->line_count > p_report) {\n+        // Every intermediate message should overwrite the previous one\n+        if (i != (oap->line_count - 1)) {\n+          msg_ext_overwrite = true;\n+        }",
