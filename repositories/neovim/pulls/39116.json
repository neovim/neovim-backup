            "author_association": "MEMBER",
            "body": "> nvim -ll is temporary\r\n\r\nOh. I thought `-ll` was a very useful feature, basically a drop-in replacement for `lua`\r\n\r\n> Meanwhile, is it not possible to make the existing vim.wait available for -ll ?\r\n\r\nIt's possible. (EDIT: quite messy)\r\n\r\n<details>\r\n<summary>Details</summary>\r\n\r\n```diff\r\ndiff --git a/src/nvim/lua/executor.c b/src/nvim/lua/executor.c\r\nindex 7c4e42420a..87f89f409d 100644\r\n--- a/src/nvim/lua/executor.c\r\n+++ b/src/nvim/lua/executor.c\r\n@@ -31,7 +31,6 @@\r\n #include \"nvim/event/defs.h\"\r\n #include \"nvim/event/loop.h\"\r\n #include \"nvim/event/multiqueue.h\"\r\n-#include \"nvim/event/time.h\"\r\n #include \"nvim/ex_cmds.h\"\r\n #include \"nvim/ex_cmds_defs.h\"\r\n #include \"nvim/ex_getln.h\"\r\n@@ -423,21 +422,16 @@ static int nlua_schedule(lua_State *const lstate)\r\n   return 2;\r\n }\r\n\r\n-// Dummy timer callback. Used by vim.wait().\r\n-static void dummy_timer_due_cb(TimeWatcher *tw, void *data)\r\n+// Dummy timer callback. Used by vim.wait() outside the editor loop.\r\n+static void dummy_uv_timer_cb(uv_timer_t *timer)\r\n {\r\n-  // If the main loop is closing, the condition won't be checked again.\r\n-  // Close the timer to avoid leaking resources.\r\n-  if (main_loop.closing) {\r\n-    time_watcher_stop(tw);\r\n-    time_watcher_close(tw, dummy_timer_close_cb);\r\n-  }\r\n+  (void)timer;\r\n }\r\n\r\n-// Dummy timer close callback. Used by vim.wait().\r\n-static void dummy_timer_close_cb(TimeWatcher *tw, void *data)\r\n+// Dummy timer close callback. Used by vim.wait() outside the editor loop.\r\n+static void dummy_uv_timer_close_cb(uv_handle_t *handle)\r\n {\r\n-  xfree(tw);\r\n+  xfree(handle);\r\n }\r\n\r\n static bool nlua_wait_condition(lua_State *lstate, int *status, bool *callback_result,\r\n@@ -512,36 +506,66 @@ static int nlua_wait(lua_State *lstate)\r\n     fast_only = lua_toboolean(lstate, 4);\r\n   }\r\n\r\n-  MultiQueue *loop_events = fast_only ? main_loop.fast_events : main_loop.events;\r\n-\r\n-  TimeWatcher *tw = xmalloc(sizeof(TimeWatcher));\r\n-\r\n-  // Start dummy timer.\r\n-  time_watcher_init(&main_loop, tw, NULL);\r\n-  // Don't schedule the due callback, as that'll lead to two different types of events\r\n-  // on each interval, causing the condition to be checked twice.\r\n-  tw->events = NULL;\r\n-  time_watcher_start(tw, dummy_timer_due_cb, (uint64_t)interval, (uint64_t)interval);\r\n-\r\n+  uv_loop_t *uv_loop = luv_loop(lstate);\r\n+  bool use_main_loop = uv_loop == &main_loop.uv;\r\n+  MultiQueue *loop_events = use_main_loop ? (fast_only ? main_loop.fast_events : main_loop.events)\r\n+                                          : NULL;\r\n   int pcall_status = 0;\r\n   bool callback_result = false;\r\n   int nresults = 0;\r\n+  uv_timer_t *timer = NULL;\r\n+  bool has_deadline = timeout < INT64_MAX && timeout <= (int64_t)(UINT64_MAX / 1000000);\r\n+  uint64_t deadline = has_deadline ? os_hrtime() + (uint64_t)timeout * 1000000 : 0;\r\n\r\n-  // Flush screen updates before blocking.\r\n-  ui_flush();\r\n+  if (use_main_loop) {\r\n+    // Flush screen updates before blocking.\r\n+    ui_flush();\r\n+  } else {\r\n+    // States with their own luv loop (for example -ll and Lua threads) cannot\r\n+    // wait on main_loop, so poll that loop directly instead.\r\n+    timer = xmalloc(sizeof(*timer));\r\n+    int uv_status = uv_timer_init(uv_loop, timer);\r\n+    if (uv_status != 0) {\r\n+      xfree(timer);\r\n+      return luaL_error(lstate, \"%s\", uv_strerror(uv_status));\r\n+    }\r\n+  }\r\n\r\n-  LOOP_PROCESS_EVENTS_UNTIL(&main_loop,\r\n-                            loop_events,\r\n-                            timeout,\r\n-                            got_int || (is_function ? nlua_wait_condition(lstate,\r\n-                                                                          &pcall_status,\r\n-                                                                          &callback_result,\r\n-                                                                          &nresults)\r\n-                                                    : false));\r\n+  while (!(use_main_loop && got_int) && !callback_result && !pcall_status) {\r\n+    if (is_function && nlua_wait_condition(lstate, &pcall_status, &callback_result, &nresults)) {\r\n+      break;\r\n+    }\r\n\r\n-  // Stop dummy timer\r\n-  time_watcher_stop(tw);\r\n-  time_watcher_close(tw, dummy_timer_close_cb);\r\n+    int64_t delay = interval;\r\n+    if (has_deadline) {\r\n+      uint64_t now = os_hrtime();\r\n+      if (now >= deadline) {\r\n+        break;\r\n+      }\r\n+      uint64_t remaining_ms = (deadline - now + 999999) / 1000000;\r\n+      delay = MIN(delay, (int64_t)remaining_ms);\r\n+    }\r\n+\r\n+    if (use_main_loop) {\r\n+      LOOP_PROCESS_EVENTS(&main_loop, loop_events, delay);\r\n+    } else {\r\n+      int uv_status = uv_timer_start(timer, dummy_uv_timer_cb, (uint64_t)delay, 0);\r\n+      if (uv_status != 0) {\r\n+        uv_close((uv_handle_t *)timer, dummy_uv_timer_close_cb);\r\n+        uv_run(uv_loop, UV_RUN_NOWAIT);\r\n+        return luaL_error(lstate, \"%s\", uv_strerror(uv_status));\r\n+      }\r\n+\r\n+      uv_run(uv_loop, UV_RUN_ONCE);\r\n+      uv_timer_stop(timer);\r\n+    }\r\n+  }\r\n+\r\n+  if (timer != NULL) {\r\n+    uv_timer_stop(timer);\r\n+    uv_close((uv_handle_t *)timer, dummy_uv_timer_close_cb);\r\n+    uv_run(uv_loop, UV_RUN_NOWAIT);\r\n+  }\r\n\r\n   if (pcall_status) {\r\n     return lua_error(lstate);\r\n@@ -554,7 +578,7 @@ static int nlua_wait(lua_State *lstate)\r\n       lua_insert(lstate, -1 - nresults);\r\n     }\r\n     return nresults + 1;\r\n-  } else if (got_int) {\r\n+  } else if (use_main_loop && got_int) {\r\n     got_int = false;\r\n     vgetc();\r\n     lua_pushboolean(lstate, 0);\r\n@@ -641,6 +665,11 @@ static void nlua_common_vim_init(lua_State *lstate, bool is_thread, bool is_stan\r\n   lua_setfield(lstate, LUA_REGISTRYINDEX, \"mpack.empty_dict\");\r\n   lua_setfield(lstate, -2, \"_empty_dict_mt\");\r\n\r\n+  if (!is_thread) {\r\n+    lua_pushcfunction(lstate, &nlua_wait);\r\n+    lua_setfield(lstate, -2, \"wait\");\r\n+  }\r\n+\r\n   // vim.uv\r\n   if (is_standalone) {\r\n     // do nothing, use libluv like in a standalone interpreter\r\n@@ -838,10 +867,6 @@ static bool nlua_state_init(lua_State *const lstate) FUNC_ATTR_NONNULL_ALL\r\n   lua_pushcfunction(lstate, &nlua_rpcnotify);\r\n   lua_setfield(lstate, -2, \"rpcnotify\");\r\n\r\n-  // wait\r\n-  lua_pushcfunction(lstate, &nlua_wait);\r\n-  lua_setfield(lstate, -2, \"wait\");\r\n-\r\n   // ui_attach\r\n   lua_pushcfunction(lstate, &nlua_ui_attach);\r\n   lua_setfield(lstate, -2, \"ui_attach\");\r\n```\r\n\r\n</details>\r\n\r\n> Though with https://github.com/neovim/neovim/pull/38116 if we can eliminate the C impl of vim.wait, that's another alternative\r\n\r\nThat was my thinking. Should we merge #38116 first?",
