            "author_association": "MEMBER",
            "body": "Don't need to check this twice. The `screen:expect()` calls below already check more.\r\n```suggestion\r\n```",
            "commit_id": "b148ee5334abc8da3195d2c302433a0c737e02b4",
            "created_at": "2026-05-19T23:32:56Z",
            "diff_hunk": "@@ -2257,6 +2257,133 @@ describe('folded lines', function()\n       end\n     end)\n \n+    it('virt_lines above line where fold begins do not duplicate foldcolumn', function()\n+      fn.setline(1, 'line 1')\n+      fn.setline(2, 'line 2')\n+      fn.setline(3, 'line 3')\n+      fn.setline(4, 'line 4')\n+\n+      local ns = api.nvim_create_namespace('ns')\n+      api.nvim_buf_set_extmark(\n+        0,\n+        ns,\n+        1,\n+        0,\n+        { virt_lines_above = true, virt_lines = { { { 'above line 2' } } } }\n+      )\n+      api.nvim_buf_set_extmark(0, ns, 2, 0, { virt_lines = { { { 'below line 3' } } } })\n+\n+      command('set foldcolumn=1')\n+      feed('jzfl')\n+      if multigrid then\n+        screen:expect([[\n+        ## grid 1\n+          [2:---------------------------------------------]|*7\n+          [3:---------------------------------------------]|\n+        ## grid 2\n+          {7: }line 1                                      |\n+          {7: }above line 2                                |\n+          {7:-}^line 2                                      |\n+          {7: }line 3                                      |\n+          {7: }below line 3                                |\n+          {7: }line 4                                      |\n+          {1:~                                            }|\n+        ## grid 3\n+                                                       |\n+        ]])\n+      else\n+        screen:expect([[\n+          {7: }line 1                                      |\n+          {7: }above line 2                                |\n+          {7:-}^line 2                                      |\n+          {7: }line 3                                      |\n+          {7: }below line 3                                |\n+          {7: }line 4                                      |\n+          {1:~                                            }|\n+                                                       |\n+        ]])\n+      end\n+",
            "html_url": "https://github.com/neovim/neovim/pull/39891#discussion_r3270321008",
