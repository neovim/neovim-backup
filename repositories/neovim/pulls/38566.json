                },
                "self": {
                    "href": "https://api.github.com/repos/neovim/neovim/pulls/comments/3018895201"
                }
            },
            "author_association": "MEMBER",
            "body": "doesn't `<end>` work?\n```suggestion\n        vim.api.nvim_feedkeys('<End>', 'n', false)\n```",
            "commit_id": "72b36105e80313148169c5837ab43e990c4628ea",
            "created_at": "2026-03-31T23:03:14Z",
            "diff_hunk": "@@ -1036,6 +1036,20 @@ function M.show_document(location, position_encoding, opts)\n       -- Open folds under the cursor\n       vim.cmd('normal! zv')\n     end)\n+\n+    -- nvim_win_set_cursor clamps to last char at EOL. In insert mode the cursor\n+    -- should be past the last char (append position).\n+    if vim.api.nvim_get_mode().mode == 'i' then\n+      local line = api.nvim_buf_get_lines(bufnr, row, row + 1, false)[1] or ''\n+      if col >= #line then\n+        vim._with({ win = win }, function()\n+          local save_ve = vim.wo.virtualedit\n+          vim.wo.virtualedit = 'onemore'\n+          api.nvim_win_set_cursor(win, { row + 1, col })\n+          vim.wo.virtualedit = save_ve\n+        end)",
