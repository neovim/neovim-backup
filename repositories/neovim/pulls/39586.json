            "author_association": "MEMBER",
            "body": "the ':cd should...\" message makes this test failure harder to read. If that message were simply dropped, we could see the \"actual\" value instead of only the \"expected\" value. \n\n```\n2026-05-04T13:36:21.0898421Z \u001b[1m\u001b[35mFAILED  \u001b[0m\u001b[0m \u001b[36m...est_xdg_ex_cmds/test/functional/ex_cmds/restart_spec.lua\u001b[0m @ \u001b[36m17\u001b[0m: \u001b[1m:restart use initial directory\u001b[0m\n2026-05-04T13:36:21.0898607Z :cd should change cwd to D:/a/neovim/neovim/build/Xtest_tmpdir_ex_cmds/T282.2\n2026-05-04T13:36:21.0898672Z stack traceback:\n2026-05-04T13:36:21.0899029Z \t...est_xdg_ex_cmds/test/functional/ex_cmds/restart_spec.lua:50: in function <...est_xdg_ex_cmds/test/functional/ex_cmds/restart_spec.lua:17>\n```",
            "commit_id": "26a5443fb92a3f2d5ab33740f3cf0125b338e622",
            "created_at": "2026-05-04T14:58:53Z",
            "diff_hunk": "@@ -0,0 +1,147 @@\n+local t = require('test.testutil')\n+local n = require('test.functional.testnvim')()\n+local tt = require('test.functional.testterm')\n+\n+local eq = t.eq\n+local feed_data = tt.feed_data\n+local retry = t.retry\n+local is_os = t.is_os\n+local new_pipename = n.new_pipename\n+\n+local env_notermguicolors = { COLORTERM = 'xterm-256color' }\n+\n+describe(':restart', function()\n+  before_each(n.clear)\n+  after_each(n.check_close)\n+\n+  it('use initial directory', function()\n+    local server_session\n+    local tmpdir = t.tmpname()\n+    finally(function()\n+      if server_session then\n+        server_session:close()\n+      end\n+      os.remove(tmpdir)\n+    end)\n+\n+    local server_pipe = new_pipename()\n+    local screen = tt.setup_child_nvim({\n+      '-u',\n+      'NONE',\n+      '-i',\n+      'NONE',\n+      '--listen',\n+      server_pipe,\n+      '--cmd',\n+      'set notermguicolors',\n+    }, { env = env_notermguicolors })\n+\n+    -- Wait for TUI to be ready before feeding keys.\n+    screen:expect({ any = 'TERMINAL' })\n+\n+    retry(nil, nil, function()\n+      server_session = n.connect(server_pipe)\n+    end)\n+    local _, init_cwd = server_session:request('nvim_call_function', 'getcwd', {})\n+    os.remove(tmpdir)\n+    server_session:request('nvim_call_function', 'mkdir', { tmpdir, 'p' })\n+    server_session:request('nvim_command', 'cd ' .. tmpdir)\n+    local _, after_cd = server_session:request('nvim_call_function', 'getcwd', {})\n+    eq(tmpdir, after_cd, ':cd should change cwd to ' .. tmpdir)",
