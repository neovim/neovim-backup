            "author_association": "MEMBER",
            "body": "Test could be stronger by comparing the whole path, otherwise this may be a false negative (the path might have both `\\` and `/` slashes).\n\n\n    t.eq(normalize(...), path)",
            "commit_id": "3d3525fb35ce8f1e8da0aec3aad82fffa2ff316f",
            "created_at": "2026-05-04T16:17:36Z",
            "diff_hunk": "@@ -76,4 +76,10 @@ describe('exepath()', function()\n       end\n     )\n   end\n+\n+  it('respects shellslash #39524', function()\n+    t.skip(not is_os('win'), \"N/A: 'shellslash' only works on Windows\")\n+    local path = call('exepath', 'cmd.exe') ---@type string\n+    t.ok(nil == path:find('/'))",
