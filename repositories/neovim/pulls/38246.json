            "created_at": "2026-03-11T08:20:58Z",
            "diff_hunk": "@@ -741,6 +742,8 @@ void terminal_close(Terminal **termpp, int status)\n   }\n \n   if (only_destroy) {\n+    // buffer may be reused so delete the \"[Process exited]\" msg\n+    extmark_del_id(buf, (uint32_t)-1, term->exitmsg_id);",
