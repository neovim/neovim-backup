            "diff_hunk": "@@ -118,6 +118,41 @@ describe('startup', function()\n     command('filetype detect')\n     eq('filetype detection:ON  plugin:OFF  indent:OFF', exec_capture('filetype'))\n   end)\n+\n+  it('opens swap file correctly when using device path #31606', function()\n+    skip(not is_os('win'), 'N/A: Windows feature')\n+    local cwd = vim.fs.normalize(vim.uv.cwd())\n+    local swapdir = cwd .. '/Xtest_swap_dir/'\n+    local drive, path = cwd:sub(1, 1), cwd:sub(3)\n+    local dos_path = cwd .. '/nonexist/file'\n+    local device_quest_path = '//?/' .. dos_path\n+    local device_dot_path = '//./' .. dos_path\n+    local device_unc_path = '//?/UNC/localhost/' .. drive .. '$' .. path\n+    clear({\n+      args = {\n+        '--embed',\n+        '--headless',\n+        '--cmd',\n+        'set directory=' .. swapdir .. '/',\n+        '--',\n+        device_quest_path,\n+      },\n+      merge = false,\n+    })\n+    eq(swapdir .. dos_path:gsub('[:/]', '%%') .. '.swp', fn.swapname('%'))\n+    command('bw!')\n+    api.nvim_buf_set_name(0, dos_path)\n+    eq(swapdir .. dos_path:gsub('[:/]', '%%') .. '.swp', fn.swapname('%'))\n+    command('bw!')\n+    api.nvim_buf_set_name(0, device_dot_path)\n+    eq(swapdir .. dos_path:gsub('[:/]', '%%') .. '.swp', fn.swapname('%'))",
