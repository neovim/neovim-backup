            "author_association": "MEMBER",
            "body": "Actually, is it possible for the `git ls-remote` above to succeed but not return `HEAD`?\r\n\r\nMaybe it's possible for the `nightly` tag to be missing though. (like if the release workflow fails after deleting the tag?)\r\n\r\n```lua\r\n  local head_sha = assert(refs['HEAD'])\r\n  local nightly_sha = refs['refs/tags/nightly']\r\n\r\n  if vim.startswith(head_sha, commit) then\r\n    vim.health.ok('Up to date (HEAD)')\r\n  elseif nightly_sha and vim.startswith(nightly_sha, commit) then\r\n    vim.health.ok('Up to date (nightly)')\r\n  else\r\n    vim.health.warn(\r\n      ('Build is outdated. Local: %s, HEAD: %s%s'):format(\r\n        commit,\r\n        head_sha:sub(1, 12),\r\n        nightly_sha and (', Nightly: ' .. nightly_sha:sub(1, 12)) or ''\r\n      )\r\n    )\r\n  end\r\n```\r\n\r\nWould this make sense? (I also gave precedence to printing `(HEAD)` over `(nightly)` if both commits are equal)",
            "commit_id": "5c0b6eb1e9035503f7d235ec4d4134e498aa9e33",
            "created_at": "2026-03-05T14:08:17Z",
            "diff_hunk": "@@ -573,20 +573,37 @@ end\n local function check_head_hash(commit)\n   local result = vim\n     .system(\n-      { 'git', 'ls-remote', 'https://github.com/neovim/neovim', 'HEAD' },\n+      { 'git', 'ls-remote', 'https://github.com/neovim/neovim', 'HEAD', 'refs/tags/nightly' },\n       { text = true, timeout = 5000 }\n     )\n     :wait()\n   if result.code ~= 0 or not result.stdout or result.stdout == '' then\n     return\n   end\n-  local upstream = assert(result.stdout:match('^(%x+)'))\n-  if not vim.startswith(upstream, commit) then\n+\n+  local refs = {} ---@type table<string, string>\n+  for line in result.stdout:gmatch('[^\\n]+') do\n+    local sha, ref = line:match('^(%x+)%s+(%S+)$')\n+    if sha and ref then\n+      refs[ref] = sha\n+    end\n+  end\n+\n+  local nightly_sha = refs['refs/tags/nightly']\n+  local head_sha = refs['HEAD']\n+\n+  if nightly_sha and vim.startswith(nightly_sha, commit) then\n+    vim.health.ok('Up to date (nightly)')\n+  elseif head_sha and vim.startswith(head_sha, commit) then\n+    vim.health.ok('Up to date (HEAD)')\n+  elseif head_sha then\n     vim.health.warn(\n-      ('Build is outdated. Local: %s, Latest: %s'):format(commit, upstream:sub(1, 12))\n+      ('Build is outdated. Local: %s, HEAD: %s, Nightly: %s'):format(\n+        commit,\n+        head_sha:sub(1, 12),\n+        nightly_sha:sub(1, 12)\n+      )",
