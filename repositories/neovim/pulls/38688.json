    "comment_regular_data": [
        {
            "author_association": "CONTRIBUTOR",
            "body": "> Honestly, this is my first time working with Zig. While I can identify the root cause, I'm not sure which of `small/fast/safe` is the most appropriate—or if it even matters. :D\r\n\r\nI opted for ReleaseSafe because it has safety checks. The alternative only applies if it was originally compiled in Debug mode, so the user likely doesn't care about speed or binary size.",
            "created_at": "2026-04-02T16:06:50Z",
            "html_url": "https://github.com/neovim/neovim/pull/38688#issuecomment-4178909150",
            "id": 4178909150,
            "issue_url": "https://api.github.com/repos/neovim/neovim/issues/38688",
