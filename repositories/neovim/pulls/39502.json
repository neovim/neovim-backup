                    "href": "https://api.github.com/repos/neovim/neovim/pulls/39502"
                },
                "self": {
                    "href": "https://api.github.com/repos/neovim/neovim/pulls/comments/3161022439"
                }
            },
            "author_association": "MEMBER",
            "body": "hmm, I assume `fs_realpath` was needed on unix to follow symlinks...",
            "commit_id": "97cd7d7e749e5af81a43051a6f2f7baa6fb8fead",
            "created_at": "2026-04-29T12:40:05Z",
            "diff_hunk": "@@ -600,8 +600,8 @@ function M.rename(old_fname, new_fname, opts)\n   opts = opts or {}\n   local skip = not opts.overwrite or opts.ignoreIfExists\n \n-  local old_fname_full = uv.fs_realpath(vim.fs.normalize(old_fname, { expand_env = false }))\n-  if not old_fname_full then\n+  local old_fname_full = vim.fs.normalize(old_fname, { expand_env = false })\n+  if not uv.fs_stat(old_fname_full) then",
