    "body": "## Problem:\r\nTry to solve problem #39552, previous attempt #40209\r\n\r\nvim.system() only supports raw uv.spawn (mode='process'). SystemObj:kill() cannot terminate descendant processes, causing orphaned process trees. Unlike jobstart/ jobstop, there is no teardown ownership for child processes.\r\n\r\n## Solution:\r\n- Add mode='job' which uses Neovim's internal job-control layer (jobstart/jobstop).\r\n- Add mode='detached' for process-group kill without teardown ownership.\r\n- Default mode='process' preserves existing behavior.",
    "closed_at": null,
    "comment_data": [
        {
            "_links": {
                "html": {
                    "href": "https://github.com/neovim/neovim/pull/40267#discussion_r3443289012"
                },
                "pull_request": {
                    "href": "https://api.github.com/repos/neovim/neovim/pulls/40267"
                },
                "self": {
                    "href": "https://api.github.com/repos/neovim/neovim/pulls/comments/3443289012"
                }
            },
            "author_association": "MEMBER",
            "body": "The direction I'd like to explore, is that all `vim.system` invocations will create jobs. Thus there is no need to add a `mode=job` type or special-case the impl like this.\n\nHow that is achieved, I'm not sure. It will require deep thought.\n\nMy instinct would probably be to : \n\n1. start by enhancing `jobstart` however needed\n2. let `vim.system` fully delegate to `jobstart`\n3. in a later phase, if we don't like that because it's \"yucky\" (\"oh noes, we're using `jobstart` instead of `vim.uv`\"), then we can think about how to make it \"pure lua\" or whatever (perhaps by introducing `nvim_jobstart`)",
            "commit_id": "e4b96ca071bbb3db538da1ad371a9396a6a951ba",
            "created_at": "2026-06-19T15:08:29Z",
            "diff_hunk": "@@ -415,25 +488,201 @@ local function _on_error(state)\n   close_handle(state.timer)\n end\n \n+--- @param data string[] Raw line array from jobstart\n+--- @param text boolean Whether to normalize line endings\n+--- @return string[]\n+local function sanitize_data(data, text)\n+  local sanitized = {}\n+\n+  for i, line in ipairs(data) do\n+    if text then\n+      --- @type string\n+      line = line:gsub('\\r$', '')\n+    end\n+\n+    if not (i == #data and line == '') then\n+      table.insert(sanitized, line)\n+    end\n+  end\n+\n+  return sanitized\n+end\n+--- @param cmd string[]\n+--- @param opts vim.SystemOpts\n+--- @param on_exit? fun(out: vim.SystemCompleted)\n+local function run_jobmode(cmd, opts, on_exit)\n+  local stdout_data = nil\n+  local stderr_data = nil\n+\n+  if opts.stdout ~= false and type(opts.stdout) ~= 'function' then\n+    stdout_data = {}\n+  end\n+\n+  if opts.stderr ~= false and type(opts.stderr) ~= 'function' then\n+    stderr_data = {}\n+  end\n+  --- @type string\n+  local stdin = 'null'\n+\n+  if\n+    type(opts.stdin) == 'string'\n+    or (type(opts.stdin) == 'table' and type(opts.stdin[1]) == 'string')\n+    or opts.stdin\n+  then\n+    stdin = 'pipe'\n+  end\n+\n+  --- @type vim.SystemState\n+  local state = {\n+    mode = 'job',\n+    done = false,\n+    cmd = cmd,\n+    timeout = opts.timeout,\n+  }\n+\n+  local job_opts = {\n+    cwd = opts.cwd,\n+    env = opts.env,\n+    clear_env = opts.clear_env,\n+    stdin = stdin,\n+    detach = false,\n+\n+    stdout_buffered = true,\n+    stderr_buffered = true,\n+\n+    on_stdout = function(_, data)\n+      if stdout_data and data then\n+        local processed_lines = sanitize_data(data, opts.text)\n+        if type(opts.stdout) == 'function' then\n+          opts.stdout(nil, table.concat(processed_lines, '\\n'))\n+        else\n+          for _, line in ipairs(processed_lines) do\n+            table.insert(stdout_data, line .. '\\n')\n+          end\n+        end\n+      end\n+    end,\n+\n+    on_stderr = function(_, data)\n+      if stderr_data and data then\n+        if type(opts.stderr) == 'function' then\n+          opts.stderr(nil, table.concat(sanitize_data(data, opts.text)))\n+        else\n+          table.insert(stderr_data, table.concat(sanitize_data(data, opts.text)))\n+        end\n+      end\n+    end,\n+\n+    on_exit = function(_, exit_code, _)\n+      local signal = 0 --- @type integer\n+      close_handle(state.timer)\n+\n+      if exit_code > 128 and exit_code <= 255 then\n+        signal = (exit_code - 128) --- @type integer\n+        exit_code = 0\n+      else\n+        signal = 0\n+      end\n+\n+      if state.done == 'timeout' then\n+        exit_code = 124\n+      end\n+\n+      _exit(\n+        state,\n+        exit_code,\n+        signal,\n+        stdout_data and table.concat(stdout_data) or nil,\n+        stderr_data and table.concat(stderr_data) or nil\n+      )\n+\n+      if on_exit then\n+        on_exit(state.result)\n+      end\n+    end,\n+  }\n+  if job_opts.env and vim.tbl_isempty(job_opts.env) then\n+    job_opts.env = nil\n+  end\n+\n+  if opts.cwd and not uv.fs_stat(opts.cwd) then\n+    error((\"ENOENT: no such file or directory (cwd): '%s'\"):format(opts.cwd))\n+  end\n+  if vim.fn.executable(cmd[1]) == 0 then\n+    error((\"ENOENT: no such file or directory (cmd): '%s'\"):format(cmd[1]))\n+  end\n+\n+  local job_id = vim.fn.jobstart(cmd, job_opts)",
