                    "href": "https://api.github.com/repos/neovim/neovim/pulls/comments/3263155648"
                }
            },
            "author_association": "MEMBER",
            "body": "how about `M.autocmd`?",
            "commit_id": "82bf93f142c252856084d69c171ceb5c271a4b59",
            "created_at": "2026-05-19T01:35:48Z",
            "diff_hunk": "@@ -172,4 +172,31 @@ function M.echo_err(msg)\n   vim.api.nvim_echo({ { msg } }, true, { err = true })\n end\n \n+--- Define event-handlers (autocmds) ergonomically.\n+---\n+--- Examples:\n+--- ```lua\n+---   local nvim_on = require('vim._core.util').nvim_on\n+---   nvim_on('BufWritePost', group, function(ev) print(ev.file) end)\n+---   nvim_on({ 'BufRead', 'BufNew' }, group, { pattern = '*.lua' }, function(ev) end)\n+---   nvim_on('VimLeavePre', nil, function() end)\n+--- ```\n+---\n+--- @param events string|string[] Event(s) to watch. See |autocmd-events|.\n+--- @param group string|integer? Augroup name or id; `nil` for no group.\n+--- @param opts_or_fn vim.api.keyset.create_autocmd|fun(ev) Options table (followed by {fn}), or the callback for the no-opts shorthand.\n+--- @param fn? fun(ev) Callback. Required when {opts_or_fn} is a table.\n+--- @return integer # Autocmd id (see |nvim_create_autocmd()|).\n+function M.nvim_on(events, group, opts_or_fn, fn)",
