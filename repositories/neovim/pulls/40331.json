            "author_association": "MEMBER",
            "body": "I didn’t see an existing helper for capturing process spawn options in the functional test utilities. If there’s a cleaner existing pattern for this let me know!",
            "commit_id": "cebac5bd860128bafa2f3b30c027329685169cab",
            "created_at": "2026-06-19T17:15:50Z",
            "diff_hunk": "@@ -2932,6 +2918,62 @@ describe('LSP', function()\n   end)\n \n   describe('cmd', function()\n+    it('cmd as a string array passes cmd_cwd, root_dir, or nil cwd to process spawn', function()\n+      local root_dir = tmpname(false)\n+      local cmd_cwd = tmpname(false)\n+      mkdir(root_dir)\n+      mkdir(cmd_cwd)\n+\n+      local cases = {\n+        {\n+          desc = 'cmd_cwd takes precedence',\n+          config = { name = 'cwd-test-cmd-cwd', root_dir = root_dir, cmd_cwd = cmd_cwd },\n+          expected_cwd = cmd_cwd,\n+        },\n+        {\n+          desc = 'root_dir is used when cmd_cwd is unset',\n+          config = { name = 'cwd-test-root-dir', root_dir = root_dir },\n+          expected_cwd = root_dir,\n+        },\n+        {\n+          desc = 'cwd is unset when cmd_cwd and root_dir are unset',\n+          config = { name = 'cwd-test-current-cwd' },\n+          expected_cwd = NIL,\n+        },\n+      }\n+\n+      local actual = exec_lua(function(test_cases)",
