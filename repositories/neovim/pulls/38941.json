            "url": "https://api.github.com/repos/neovim/neovim/issues/comments/4232656668",
            "user": {
                "avatar_url": "https://avatars.githubusercontent.com/u/107814000?v=4",
                "events_url": "https://api.github.com/users/altermo/events{/privacy}",
