            "author_association": "NONE",
            "body": "Deleting `glob_files` in both `before_each` and `after_each` for every test in this describe block adds per-test overhead for tests that don't use these files. Consider scoping the setup/teardown to a nested `describe` block around the new `:edit` glob test, or performing the create+delete inside the test itself, so unrelated tests aren't affected.\n",
            "commit_id": "2651bcf83468f320d9def35d7e9b2b531f4192f3",
            "created_at": "2026-05-18T00:44:34Z",
            "diff_hunk": "@@ -22,8 +23,19 @@ describe('nlua_call_excmd excmds', function()\n end)\n \n describe('excmds', function()\n+  local glob_files = { 'Xedit_glob_one.js', 'Xedit_glob_two.js' }\n+\n   before_each(function()\n     clear()\n+    for _, file in ipairs(glob_files) do\n+      fn.delete(file)\n+    end\n+  end)\n+\n+  after_each(function()\n+    for _, file in ipairs(glob_files) do\n+      fn.delete(file)\n+    end",
