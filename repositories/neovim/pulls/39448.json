            "body": "AI generated benchmark report\r\n\r\n---\r\n\r\nBenchmark for Tree-sitter highlighting in a C buffer with 100k `preproc_arg`\r\nself-injections. The base run overlays only\r\n`runtime/lua/vim/treesitter/languagetree.lua` from `NVIM_BENCH_BASE_REF`.\r\n\r\nSetup:\r\n\r\n- Start the built-in highlighter.\r\n- Fully parse before each measured edit to restore child injection regions.\r\n- Edit a different macro line each round.\r\n- Time the one-line parse requested after the edit.\r\n\r\nLocal debug build: `NVIM_BENCH_N=100000`, `NVIM_BENCH_ROUNDS=25`,\r\n`NVIM_BENCH_RUNS=3`, `NVIM_BENCH_BASE_REF=master`.\r\nRanges combine all measured edits from the 3 fresh Nvim processes. Speedup\r\ncompares the low endpoints and high endpoints.\r\n\r\n| Lua runtime | This PR range | Base range | Speedup |\r\n| --- | ---: | ---: | ---: |\r\n| LuaJIT | 68.7–200.8 ms | 144.0–305.3 ms | 1.5–2.1x |\r\n| LuaJIT JIT off | 75.0–209.8 ms | 137.3–286.3 ms | 1.4–1.8x |\r\n| PUC Lua 5.1 | 217.2–299.9 ms | 229.2–330.6 ms | 1.1–1.1x |\r\n\r\nNotes:\r\n\r\n- LuaJIT is the normal build; JIT-off and PUC Lua are sanity checks.\r\n- Markdown fences and template islands should hit the same LanguageTree path,\r\n  but are not measured here.\r\n\r\n<details>\r\n<summary><code>run-nvim-ts-range-bench.sh</code></summary>\r\n\r\n```sh\r\n#!/usr/bin/env sh\r\nset -eu\r\n\r\n# Run from the Neovim repository root after building `build/bin/nvim`.\r\n\r\nbench_lua=${NVIM_BENCH_LUA:-./nvim-ts-range-bench.lua}\r\nbase_runtime=${NVIM_BENCH_BASE_RUNTIME:-./nvim-base-runtime}\r\nbase_ref=${NVIM_BENCH_BASE_REF:-master}\r\n\r\nexport VIMRUNTIME=\"$PWD/runtime\"\r\nexport NVIM_BENCH_NVIM=${NVIM_BENCH_NVIM:-build/bin/nvim}\r\nexport NVIM_BENCH_N=${NVIM_BENCH_N:-100000}\r\nexport NVIM_BENCH_ROUNDS=${NVIM_BENCH_ROUNDS:-25}\r\nexport NVIM_BENCH_RUNS=${NVIM_BENCH_RUNS:-3}\r\nexport NVIM_BENCH_JIT_OFF=${NVIM_BENCH_JIT_OFF:-0}\r\nexport NVIM_BENCH_VERBOSE=${NVIM_BENCH_VERBOSE:-0}\r\n\r\nmkdir -p \"$base_runtime/lua/vim/treesitter\"\r\ngit show \"$base_ref\":runtime/lua/vim/treesitter/languagetree.lua \\\r\n  > \"$base_runtime/lua/vim/treesitter/languagetree.lua\"\r\n\r\nrange_value() {\r\n  printf '%s' \"$1\" | awk '\r\n    NF == 2 {\r\n      if (!n || $1 < min) min = $1\r\n      if (!n || $2 > max) max = $2\r\n      n++\r\n    }\r\n    END { printf \"%.3f %.3f %d\", min, max, n }\r\n  '\r\n}\r\n\r\nrun_case() {\r\n  label=$1\r\n  overlay=${2:-}\r\n  run=1\r\n  values=\r\n\r\n  while [ \"$run\" -le \"$NVIM_BENCH_RUNS\" ]; do\r\n    printf '%s\\n' \"--- $label run $run/$NVIM_BENCH_RUNS ---\"\r\n    if [ -n \"$overlay\" ]; then\r\n      output=$(NVIM_BENCH_RUNTIME_OVERLAY=\"$overlay\" \"$NVIM_BENCH_NVIM\" --headless -l \"$bench_lua\" 2>&1)\r\n    else\r\n      output=$(\"$NVIM_BENCH_NVIM\" --headless -l \"$bench_lua\" 2>&1)\r\n    fi\r\n    printf '%s\\n' \"$output\"\r\n    values=\"${values}$(printf '%s\\n' \"$output\" | awk '/^highlighter_range_ms / { print $2, $3 }')\r\n\"\r\n    run=$((run + 1))\r\n  done\r\n\r\n  set -- $(range_value \"$values\")\r\n  printf '%s summary: highlighter_range=[%.3f,%.3f] runs=%d\\n' \"$label\" \"$1\" \"$2\" \"$3\"\r\n}\r\n\r\nrun_case 'this PR'\r\nrun_case \"base: $base_ref\" \"$base_runtime\"\r\n```\r\n\r\n</details>\r\n\r\n<details>\r\n<summary><code>nvim-ts-range-bench.lua</code></summary>\r\n\r\n```lua\r\nlocal jit_off = vim.env.NVIM_BENCH_JIT_OFF == '1' and jit ~= nil\r\nif jit_off then\r\n  jit.off()\r\n  jit.flush()\r\nend\r\n\r\nlocal overlay = vim.env.NVIM_BENCH_RUNTIME_OVERLAY\r\nif overlay and overlay ~= '' then\r\n  vim.opt.runtimepath:prepend(overlay)\r\n  package.loaded['vim.treesitter.languagetree'] = nil\r\n  package.loaded['vim.treesitter.highlighter'] = nil\r\nend\r\n\r\nlocal function range(values)\r\n  local min = values[1]\r\n  local max = values[1]\r\n  for i = 2, #values do\r\n    min = math.min(min, values[i])\r\n    max = math.max(max, values[i])\r\n  end\r\n  return min, max\r\nend\r\n\r\nlocal function lua_engine()\r\n  if not jit then\r\n    return _VERSION\r\n  end\r\n  return jit_off and jit.version .. ' jit-off' or jit.version\r\nend\r\n\r\nlocal verbose = vim.env.NVIM_BENCH_VERBOSE == '1'\r\nlocal n = tonumber(vim.env.NVIM_BENCH_N)\r\nlocal rounds = tonumber(vim.env.NVIM_BENCH_ROUNDS)\r\n\r\nlocal lines = {}\r\nfor i = 1, n do\r\n  lines[i] = ('#define VALUE_%06d %d'):format(i, i)\r\nend\r\nvim.api.nvim_buf_set_lines(0, 0, -1, false, lines)\r\nvim.bo.filetype = 'c'\r\n\r\nvim.treesitter.start(0, 'c')\r\nlocal parser = vim.treesitter.get_parser(0, 'c')\r\n\r\n-- Build the highlighter parser state with all injected child trees.\r\nparser:parse(true)\r\nlocal child_trees = vim.tbl_count(parser:children().c:trees())\r\nassert(child_trees == n, ('expected %d child trees, got %d'):format(n, child_trees))\r\n\r\nlocal times = {}\r\nfor iter = 1, rounds do\r\n  -- Restore all child regions so each edit measures the expensive replacement path.\r\n  parser:parse(true)\r\n\r\n  local edit_row = math.floor(iter * n / (rounds + 1))\r\n\r\n  -- nvim_buf_set_lines() triggers parser buffer callbacks. Redraw then asks for parse().\r\n  vim.api.nvim_buf_set_lines(0, edit_row, edit_row + 1, false, {\r\n    ('#define VALUE_%06d changed_%d'):format(edit_row + 1, iter),\r\n  })\r\n\r\n  local start = vim.uv.hrtime()\r\n  parser:parse({ edit_row, edit_row + 1 })\r\n  times[#times + 1] = (vim.uv.hrtime() - start) / 1e6\r\nend\r\n\r\nprint(('lua=%s'):format(lua_engine()))\r\nprint(('loaded_languagetree=%s'):format(debug.getinfo(getmetatable(parser).parse, 'S').source))\r\nprint(('n=%d rounds=%d child_trees=%d'):format(n, rounds, child_trees))\r\n\r\nlocal min, max = range(times)\r\nif verbose then\r\n  print(('highlighter_range_ms %.3f %.3f all=%s'):format(min, max, vim.inspect(times)))\r\nelse\r\n  print(('highlighter_range_ms %.3f %.3f'):format(min, max))\r\nend\r\n```\r\n\r\n</details>\r\n\r\nRun from the Neovim repository root after building `build/bin/nvim`:\r\n\r\n```sh\r\n./run-nvim-ts-range-bench.sh\r\n```\r\n\r\nOptional variants:\r\n\r\n```sh\r\nNVIM_BENCH_N=10000 NVIM_BENCH_ROUNDS=5 ./run-nvim-ts-range-bench.sh\r\nNVIM_BENCH_RUNS=5 ./run-nvim-ts-range-bench.sh\r\nNVIM_BENCH_VERBOSE=1 ./run-nvim-ts-range-bench.sh\r\nNVIM_BENCH_JIT_OFF=1 ./run-nvim-ts-range-bench.sh\r\nNVIM_BENCH_NVIM=build-puc/bin/nvim ./run-nvim-ts-range-bench.sh\r\nNVIM_BENCH_BASE_REF=master ./run-nvim-ts-range-bench.sh\r\n```\r\n\r\n",
