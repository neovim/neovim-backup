            "created_at": "2026-02-25T11:17:52Z",
            "diff_hunk": "@@ -0,0 +1,18 @@\n+<!DOCTYPE html>\n+<html lang=\"{{ site.Language.LanguageCode }}\">\n+\n+<head>\n+  <title>{{ .Permalink }}</title>\n+  {{ with .OutputFormats.Canonical }}<link rel=\"{{ .Rel }}\" href=\"{{ .Permalink }}\">{{ end }}",
